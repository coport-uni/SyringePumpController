{
  "env": {
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50"
  },
  "permissions": {
    "allow": [
      "Bash(gh api *)",
      "Read(//dev/**)",
      "Bash(lsusb)",
      "Bash(dmesg)",
      "Bash(stty -F /dev/ttyUSB0 -a)",
      "Read(//sys/class/tty/ttyUSB0/**)",
      "Bash(git commit -m ' *)",
      "Bash(.venv/bin/python -c \"from sy01b import Pump; print\\(Pump.__version__\\); print\\(Pump.StatusByte\\(busy=False, error=Pump.ErrorCode.OK, raw=0x40\\)\\); print\\(Pump.CMD_QUERY_SERIAL_NUMBER\\); cfg = Pump.Config\\(port='/dev/null', syringe_uL=125\\); print\\(cfg\\); print\\('step_mode default:', cfg.step_mode\\); print\\('stall:', cfg.stall_current_operand\\(\\)\\)\")",
      "Bash(.venv/bin/ruff check *)",
      "Bash(.venv/bin/ruff format *)",
      "Bash(.venv/bin/mypy)",
      "Bash(.venv/bin/pytest --cov=sy01b --cov-report=term-missing)",
      "Bash(.venv/bin/python main.py)",
      "Bash(.venv/bin/sy01b-diagnose --help)",
      "Bash(.venv/bin/sy01b-diagnose --port /dev/ttyUSB1 --address 1 --syringe-uL 125)",
      "Bash(grep -rEn \"Pump\\([^.A-Za-z_]|$\\)\" --include=\"*.py\" /workspace/SyringePumpController/src /workspace/SyringePumpController/tests /workspace/SyringePumpController/main.py)",
      "Bash(git mv *)",
      "Bash(.venv/bin/pytest -q)",
      "Bash(ls /root/.claude/plans/ 2>/dev/null || echo \"plans dir does not exist\")",
      "Read(//root/.claude/plans/**)",
      "Bash(git -C /workspace/SyringePumpController log --oneline -n 20)",
      "Bash(git -C /workspace/SyringePumpController remote -v)",
      "Bash(python3)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.github.com)",
      "Bash(cp claude_test/README.md /tmp/readme_workingtree_backup.md && git checkout HEAD -- claude_test/README.md && echo \"---HEAD README restored:---\" && cat claude_test/README.md)",
      "Bash(chmod +x .claude/hooks/*.sh)",
      "Bash(which jq)",
      "Bash(bash -n .claude/hooks/*.sh)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git rebase *)",
      "Bash(git -C /tmp/sy01b-volume-api push origin --delete feat/plunger-volume-api)",
      "Bash(git -C /tmp/sy01b-volume-api checkout main)",
      "Bash(git -C /tmp/sy01b-volume-api branch -D feat/plunger-volume-api)",
      "Bash(git clone *)",
      "Bash(git -C /tmp/sy01b-server-phase-a log --oneline -3)",
      "Bash(git -C /tmp/sy01b-server-phase-a status)",
      "Bash(git -C /tmp/sy01b-server-phase-a branch --show-current)",
      "Bash(git -C /tmp/sy01b-server-phase-a checkout -b feat/server-fastapi-bridge)",
      "Bash(python3 -m venv .venv)",
      "Bash(.venv/bin/python -c \"from server.app import create_app; print\\('server import OK'\\)\")",
      "Bash(.venv/bin/python -c \"import sys; print\\('\\\\n'.join\\(sys.path\\)\\)\")",
      "Bash(.venv/bin/pip show *)",
      "Bash(.venv/bin/pytest --cov=sy01b --cov=server --cov-report=term-missing)",
      "Bash(git -C /tmp/sy01b-server-phase-a commit -m ' *)",
      "Bash(.venv/bin/python -c \"from server.app import create_app; app = create_app\\(\\); print\\('openapi paths:', list\\(app.openapi\\(\\)['paths'].keys\\(\\)\\)\\)\")",
      "Bash(.venv/bin/sy01b-server --help)",
      "Bash(git -C /tmp/sy01b-server-phase-a push -u origin feat/server-fastapi-bridge)",
      "Bash(git -C /tmp/sy01b-firmware-phase-b checkout -b feat/firmware-skeleton)",
      "Bash(git -C /tmp/sy01b-firmware-phase-b log --oneline -3)",
      "Bash(clang-format --version)",
      "Bash(cppcheck --version)",
      "Bash(clang-format --dry-run --Werror firmware/main/*.c firmware/main/*.h)",
      "Bash(echo \"=== exit: $? ===\")",
      "Bash(clang-format -i firmware/main/*.c firmware/main/*.h)",
      "Bash(cppcheck --enable=warning,style --suppress=missingIncludeSystem --suppress=unusedFunction --suppress=unusedStructMember --error-exitcode=1 --language=c firmware/main/)",
      "Bash(git ls-tree *)",
      "Bash(git log *)",
      "Bash(git -C /tmp/sy01b-firmware-phase-c checkout -b feat/firmware-motion-ui)",
      "Bash(git -C /tmp/sy01b-firmware-phase-c log --oneline -3)",
      "Bash(timeout 5 .venv/bin/sy01b-diagnose --port /dev/ttyUSB0 --address 1 --syringe-uL 125)",
      "Bash(timeout 5 .venv/bin/sy01b-diagnose --port /dev/ttyUSB4 --address 1 --syringe-uL 125)",
      "Bash(.venv/bin/python -c \"from sy01b import SyringePumpController; print\\([\\(m.name, m.value\\) for m in SyringePumpController.StepMode]\\)\")",
      "Bash(curl -s http://localhost:17046/v1/health)",
      "Bash(python3 -m json.tool)",
      "Bash(curl -s http://localhost:17046/v1/diagnose)",
      "Bash(curl -s http://localhost:17046/v1/status)",
      "Bash(echo \"=== EXIT $? ===\")",
      "Bash(cd /workspace/SyringePumpController *)",
      "Bash(.venv/bin/python -c \"import sy01b; print\\('pkg __version__:', sy01b.__version__\\)\")",
      "Bash(grep -c '```mermaid' CODE_REVIEW_GUIDE.ko.md)",
      "Bash(grep -c '^```$' CODE_REVIEW_GUIDE.ko.md)",
      "Bash(git reflog *)"
    ],
    "additionalDirectories": [
      "/root/.claude/projects/-workspace-SyringePumpController",
      "/tmp",
      "/workspace/SyringePumpController/claude_test/tests"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-write-guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-bash-secret-scan.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-read-env-guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-write-lint.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-write-debug-remind.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Before stopping, verify: 1) If any task was performed, does ToDo.md have a corresponding entry? 2) Was a GitHub issue created via gh? 3) If Python files were modified, did ruff checks pass? 4) If files were added to claude_test/, was claude_test/README.md updated? If any check fails, block and explain what is missing.",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
